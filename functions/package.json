{
  "name": "functions",
  "description": "Cloud Functions for Firebase",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "npm run build",
    "test:rules": "firebase emulators:exec --only firestore \"node tests/firestore.rules.test.js\"",
    "backfill:dry-run": "node scripts/backfill-legacy-data.js --dry-run",
    "backfill:apply": "node scripts/backfill-legacy-data.js --apply",
    "recover:disabled-users:dry-run": "node scripts/reactivate-unbanned-disabled-users.js --dry-run",
    "recover:disabled-users:apply": "node scripts/reactivate-unbanned-disabled-users.js --apply"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/node": "^24.5.2",
    "firebase-functions-test": "^3.1.0",
    "typescript": "^5.9.2"
  },
  "private": true
}
