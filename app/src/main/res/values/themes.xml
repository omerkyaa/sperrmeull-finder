<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme using AppCompat (guaranteed to work) -->
    <style name="Theme.SperrmullFinder" parent="Theme.AppCompat.DayNight">
        <item name="colorPrimary">@color/sperrmull_primary</item>
        <item name="colorPrimaryDark">@color/sperrmull_primary_dark</item>
        <item name="colorAccent">@color/sperrmull_secondary</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:statusBarColor">@color/sperrmull_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
    
    <!-- NoActionBar variant -->
    <style name="Theme.SperrmullFinder.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/sperrmull_primary</item>
        <item name="colorPrimaryDark">@color/sperrmull_primary_dark</item>
        <item name="colorAccent">@color/sperrmull_secondary</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:statusBarColor">@color/sperrmull_primary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.SperrmullFinder.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sperrmull_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/app_logo</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="postSplashScreenTheme">@style/Theme.SperrmullFinder</item>
    </style>
</resources>